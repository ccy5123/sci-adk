# Normalize line endings: store text as LF, keep binaries intact.
# Prevents CRLF churn from cross-platform editing (WSL + Windows tools).
# text=auto lets git auto-detect text vs binary; eol=lf stores text as LF.
* text=auto eol=lf

# Explicit binaries (never EOL-normalized)
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.pyc  binary
