{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "science-orchestrator",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/sci-adk/stop-verify-gate.sh\"",
            "timeout": 30000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/sci-adk/reanchor.sh\"",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
